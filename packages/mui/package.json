{
  "name": "banhatten-ui-mui",
  "version": "0.1.1",
  "description": "Banhatten Design System theme for Material UI — plug and play",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./css/tokens.css": "./dist/css/tokens.css"
  },
  "bin": {
    "banhatten-ui-mui": "./bin/cli.js"
  },
  "files": [
    "dist",
    "bin",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mui",
    "material-ui",
    "theme",
    "design-system",
    "banhatten",
    "react",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/khaaledashraaf/banhatten-ds.git",
    "directory": "packages/mui"
  },
  "peerDependencies": {
    "@mui/material": "^5.0.0 || ^6.0.0",
    "@emotion/react": "^11.0.0",
    "@emotion/styled": "^11.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@emotion/react": {
      "optional": false
    },
    "@emotion/styled": {
      "optional": false
    }
  },
  "devDependencies": {
    "@mui/material": "^5.17.1",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.0.0"
  }
}
